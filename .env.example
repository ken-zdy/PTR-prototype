# Figma Personal Access Token（个人访问令牌）
# 获取方式：Figma → 右上角头像 → Settings → Security → Personal access tokens → Generate new token
# 把令牌粘贴到下面（不要提交到 git，.env 已被 .gitignore 忽略）
FIGMA_TOKEN=

# 前端访问密码（用于原型访问门禁）
VITE_ACCESS_PASSWORD=ptr2026

# 本地留言服务（SQLite）
# 默认值为 http://localhost:8787/api/comments
# 若服务部署到其他地址，可在此覆盖
VITE_COMMENTS_API_URL=http://localhost:8787/api/comments

# 页面左下角版本号（可选）
VITE_APP_VERSION=v0.2.1
